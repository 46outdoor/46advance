{
  "name": "@46advance/pwa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "typecheck:tests": "tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:emulator": "FIREBASE_PROJECT=demo-46advance ./scripts/cli/firebase-safe.sh emulators:exec --only auth,firestore,storage \"playwright test --config playwright.emulator.config.ts\"",
    "test:rules": "FIREBASE_PROJECT=demo-46advance ./scripts/cli/firebase-safe.sh emulators:exec --only firestore,storage \"vitest run --config vitest.rules.config.ts\"",
    "arch:check": "depcruise src --config .dependency-cruiser.cjs",
    "deadcode": "node scripts/deadcode-check.mjs",
    "dev:emulator": "FIREBASE_PROJECT=demo-46advance ./scripts/cli/firebase-safe.sh emulators:start --only auth,firestore",
    "emulators": "FIREBASE_PROJECT=demo-46advance ./scripts/cli/firebase-safe.sh emulators:start"
  },
  "dependencies": {
    "@sentry/react": "^10.67.0",
    "@tanstack/react-query": "^5.101.4",
    "@tanstack/react-virtual": "^3.14.8",
    "firebase": "^11.1.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-easy-crop": "^6.2.2",
    "react-router-dom": "^7.18.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.61.1",
    "@sentry/vite-plugin": "^4.9.1",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.20.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.7",
    "dependency-cruiser": "^16.8.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^15.14.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.0.0",
    "ts-prune": "^0.10.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.65.0",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.0.0"
  }
}
