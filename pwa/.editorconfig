# EditorConfig — https://editorconfig.org
# Codifies the formatting baseline already enforced by Prettier (.prettierrc.json)
# and ESLint so non-Prettier editors and non-formatted files (JSON, YAML, configs)
# stay consistent.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown uses two trailing spaces as a hard line break, so keep trailing
# whitespace here.
[*.md]
trim_trailing_whitespace = false
