{
  // Type-checks the test files and the emulator harness, which the deploy build
  // (tsconfig.json) deliberately excludes so they never ship. `noEmit` — this config
  // exists only to catch type errors in *.test.ts / *.emulator.test.ts / src/testing
  // that the production build would otherwise miss. Wired into CI via `typecheck:tests`.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    // *.emulator.test.ts run under vitest `globals: true` (vitest.emulator.config.ts),
    // so describe/it/expect are ambient there; node globals cover process/Buffer.
    "types": ["vitest/globals", "node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib"]
}
