{
  "name": "functions",
  "description": "Cloud Functions for 46 Advance (shared backend)",
  "private": true,
  "type": "commonjs",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:emulator": "FIREBASE_PROJECT=demo-46advance ../scripts/cli/firebase-safe.sh emulators:exec --only auth,firestore --config ../firebase.json \"vitest run --config vitest.emulator.config.ts\"",
    "serve": "npm run build && FIREBASE_PROJECT=demo-46advance ../scripts/cli/firebase-safe.sh emulators:start --only functions,auth,firestore --config ../firebase.json"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^7.2.5",
    "googleapis": "^144.0.0",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.24",
    "@types/react": "^19.2.17",
    "firebase-functions-test": "^3.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  }
}
