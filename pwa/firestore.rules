rules_version = '2';

// Per-event RBAC (Phases 1–3). Mirrors src/lib/rbac/permissions.ts and
// src/lib/advances/sections.ts — keep in sync.
//
//   approved gate      (token.approved == true)   -> required for all app access (admins exempt)
//   global admin       (token.admin == true)     -> everything
//   global organizer   (token.organizer == true) -> may create events (must also be approved)
//   production-manager (per-event role)           -> read + write stages/advances + flag
//   department-lead    (per-event role)           -> read + flag
//   tech               (per-event role)           -> read
//
// Pending/revoked accounts (no `approved` claim) are blocked here, not just in the UI
// (AuthGate). syncUserClaims grants `approved` once an admin approves the account.
// event → stages → advances. Per-event membership covers all of an event's stages.
// Anything not matched below is denied.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.get('admin', false) == true;
    }

    function isOrganizer() {
      return isSignedIn() && request.auth.token.get('organizer', false) == true;
    }

    // Approved-user gate: an account an admin has approved (or an admin itself).
    // Mirrors the UI AuthGate + the `approved` custom claim set by syncUserClaims.
    function isApproved() {
      return isSignedIn() && request.auth.token.get('approved', false) == true;
    }

    function isActiveUser() {
      return isAdmin() || isApproved();
    }

    function memberPath(eventId) {
      return /databases/$(database)/documents/events/$(eventId)/members/$(request.auth.uid);
    }

    function isMember(eventId) {
      return isActiveUser() && exists(memberPath(eventId));
    }

    function hasEventRole(eventId, role) {
      return isMember(eventId) && get(memberPath(eventId)).data.role == role;
    }

    function canEditEvent(eventId) {
      return isAdmin() || hasEventRole(eventId, 'production-manager');
    }

    function canFlagEvent(eventId) {
      return isAdmin()
        || hasEventRole(eventId, 'production-manager')
        || hasEventRole(eventId, 'department-lead');
    }

    // ---- Document shape validators (mirror the client Zod parsers in src/lib/*) ----
    // `.get(key, default)` keeps these absent-safe: a missing key yields the default
    // (and fails the check) instead of raising an evaluation error.
    // NOTE: rules can't iterate arrays/maps, so per-element shape — quote
    // lineItems[].quantity/unitPrice >= 0 and advance sections.*.status — is NOT
    // enforced here; the client Zod parsers (and, later, callable schemas) own it.
    function nonEmptyStr(data, key) {
      return data.get(key, '') is string && data.get(key, '').size() > 0;
    }
    function fieldIn(data, key, allowed) {
      return data.get(key, '') in allowed;
    }
    // True if none of `keys` changed between the stored and incoming doc (immutable /
    // server-owned fields). Update-only — there is no `resource` on create.
    function keysUnchanged(keys) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(keys);
    }

    // App-wide department list: any approved user reads; admin manages.
    match /departments/{deptId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    // App-wide document category list: any approved user reads; admin manages.
    match /documentCategories/{categoryId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    // Artist document library: any approved user reads; admin/organizer classify, delete,
    // and record their own uploads (doc id = the Drive file id; audit field pinned).
    // Bulk creation stays server-side (importDriveFolder, Admin SDK).
    match /artistDocuments/{docId} {
      allow read: if isActiveUser();
      // Server-only (S8): registered by the registerArtistDocument callable (Admin SDK), which
      // verifies the file's Drive provenance under the library root first (F-1). No client create.
      allow create: if false;
      // Curation only: admin/organizer may (re)classify + annotate (categoryId, displayName, notes,
      // obsolete, verifiedAt). The trusted Drive source metadata the callable recorded is immutable
      // to clients (F-3/WS-A) — else a client could repoint name/link/mime to a file it never proved
      // provenance for. Relinking is server-only (re-register via the callable).
      allow update: if isActiveUser() && (isAdmin() || isOrganizer())
        && keysUnchanged(['fileId', 'name', 'mimeType', 'iconLink', 'webViewLink',
                          'artist', 'artistKey', 'sourceFolderId',
                          'importedBy', 'importedByEmail', 'importedAt']);
      allow delete: if isActiveUser() && (isAdmin() || isOrganizer());
    }

    // Event templates (blueprints): any approved user reads (event-create picker);
    // admin authors. Cloning runs server-side (createEventFromTemplate, Admin SDK).
    match /templates/{templateId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    // Reusable schedule templates (day-first blueprints): any approved user reads (import
    // picker); admin/organizer author. Applying one seeds events/{e}/scheduleDays (gated there).
    match /scheduleTemplates/{templateId} {
      allow read: if isActiveUser();
      allow write: if isActiveUser() && (isAdmin() || isOrganizer());
    }

    // App-level branding config (config/branding): shared default logo marks. Any approved user reads; admin manages.
    match /config/{configId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    // Global contact directory (ROADMAP §11): reference data, distinct from RBAC users.
    // Any approved member reads + adds; the creator (or admin) edits/deletes. A user may also
    // update the entry linked to their own account (userId == them) — e.g. their profile photo.
    match /contacts/{contactId} {
      allow read: if isActiveUser();
      // `userId` links a contact to an account (profile mirror). A client may only create an
      // unlinked contact or one linked to THEMSELVES — never spoof a link to another account.
      // The server-created self-mirror (syncUserClaims, Admin SDK) bypasses these rules.
      allow create: if isActiveUser()
        && request.resource.data.createdBy == request.auth.uid
        && (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid);
      // Ordinary clients (the creator, or a user linked via userId — e.g. editing their own
      // profile photo) may update, but NOT rewrite the ownership/link fields: `createdBy` and
      // `userId` are immutable to them (F-3). Otherwise a linked user could seize `createdBy`
      // and then satisfy the creator-only delete. Legitimate relinking is admin-only (or the
      // Admin-SDK server path, which bypasses these rules).
      allow update: if isAdmin()
        || (isActiveUser()
            && (resource.data.createdBy == request.auth.uid || resource.data.userId == request.auth.uid)
            && keysUnchanged(['createdBy', 'userId']));
      allow delete: if isAdmin()
        || (isActiveUser() && resource.data.createdBy == request.auth.uid);
    }

    // User profiles are server-managed (Admin SDK). Self/admin read; no client write.
    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow write: if false;
    }

    // Google connection STATUS (Phase 11b) — non-secret mirror written by the Admin SDK
    // (OAuth callback). Owner or admin reads to render connect/disconnect UI; no client
    // write. Refresh/access tokens live in googleTokens/{uid} (server-only, below).
    match /googleConnections/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow write: if false;
    }

    // OAuth refresh/access tokens and the single-use CSRF state — Admin SDK only,
    // never client-readable or client-writable.
    match /googleTokens/{uid} {
      allow read, write: if false;
    }
    match /googleOAuthStates/{stateId} {
      allow read, write: if false;
    }
    // Distributed rate-limit counters — written only by the Admin SDK (bypasses rules).
    match /rateLimits/{limitId} {
      allow read, write: if false;
    }

    // Canonical event-slug reservations (WS-G): doc id = the slug, body `{ eventId }`. The
    // uniqueness lock behind event URLs — claimed/released ONLY by the Admin SDK (createBlankEvent,
    // createEventFromTemplate, renameEventSlug), which bypasses these rules. Never client-touchable;
    // slug resolution (getEventBySlugOrId) queries the events collection, not this one.
    match /slugs/{slug} {
      allow read, write: if false;
    }

    // Collection-group read for the non-admin events-list query
    // (`collectionGroup('members').where('uid','==', me)` in events-service.listEvents):
    // a signed-in user may list their OWN membership rows across every event, and no one
    // else's. collectionGroup() queries only match a `/{path=**}/` rule, so this must live
    // at the top level; direct member-doc access + all writes stay on the nested
    // events/{eventId}/members rule below. Read-only — writes are unaffected.
    match /{path=**}/members/{memberUid} {
      allow read: if isActiveUser() && request.auth.uid == resource.data.uid;
    }

    match /events/{eventId} {
      allow read: if isAdmin() || isMember(eventId);
      // Server-only (S8): events are created atomically with the creator's PM membership by the
      // createBlankEvent / createEventFromTemplate callables (Admin SDK), so an event can never
      // exist without its membership (WS-G). No client create.
      allow create: if false;
      allow update: if canEditEvent(eventId)
        && request.resource.data.createdBy == resource.data.createdBy // owner immutable
        && nonEmptyStr(request.resource.data, 'name')
        && fieldIn(request.resource.data, 'status', ['draft', 'active', 'archived'])
        && keysUnchanged(['googleCalendarId']); // server-owned (createEventCalendar)
      allow delete: if isAdmin();

      // Membership: admin-managed, OR the event's creator bootstrapping as PM.
      // NOTE: this nested rule governs DIRECT member-doc access (roster read, writes).
      // The non-admin events-list *collection-group* query is authorized separately by
      // the `/{path=**}/members` rule at the top of this service — nested rules do not
      // apply to collectionGroup() queries.
      match /members/{memberUid} {
        allow read: if isAdmin()
          || (isActiveUser() && request.auth.uid == memberUid)
          || isMember(eventId);
        // Admin adds members; the creator's own PM membership is created server-side by the
        // createBlankEvent callable (Admin SDK) — NOT client self-bootstrap — so a removed creator
        // can't recreate a PM membership (WS-B, S8).
        allow create: if isAdmin();
        allow update, delete: if isAdmin();
      }

      // Stages: members read; PM/admin write.
      match /stages/{stageId} {
        allow read: if isAdmin() || isMember(eventId);
        allow create, update, delete: if canEditEvent(eventId);

        // Advances live under a stage. Member read; PM/admin write (section
        // finalize/unlock ride the update gate, so tech/dept-lead can't change status).
        match /advances/{advanceId} {
          // `googleCalendarEventId` is NOT locked yet: manual attach is moving server-side to the
          // atomic attachCallBooking callable (WS-G), but the pre-Hosting client still writes it
          // here — lock it (and callBookings below) once the new client ships. Linked Drive files
          // live in the `driveFiles` subcollection below (server-owned), not on this doc.
          allow read: if isAdmin() || isMember(eventId);
          allow create: if canEditEvent(eventId)
            && request.resource.data.createdBy == request.auth.uid
            && nonEmptyStr(request.resource.data, 'artistName');
          allow update: if canEditEvent(eventId)
            && request.resource.data.createdBy == resource.data.createdBy // owner immutable
            && nonEmptyStr(request.resource.data, 'artistName');
          allow delete: if canEditEvent(eventId);

          // Linked Google Drive files — server-written only (link/removeDriveFile
          // callables; the Admin SDK bypasses rules). Members read; no client write.
          match /driveFiles/{fileId} {
            allow read: if isAdmin() || isMember(eventId);
            allow write: if false;
          }

          // Included artist documents (Documents PR 3): per-advance curation of the
          // library — doc id = the artistDocuments id. Members read; advance editors
          // (admin / event PM) curate. `includePacket` rides the update gate for the
          // packet-embedding PR; the audit fields stay immutable.
          match /documents/{docId} {
            allow read: if isAdmin() || isMember(eventId);
            // Server-only (S8): included via the includeArtistDocumentOnAdvance callable (Admin
            // SDK), which copies the canonical artistDocuments metadata (F-1). No client create.
            allow create: if false;
            // Only `includePacket` (packet-embed toggle) is client-editable curation; the audit
            // fields AND the copied Drive source metadata are immutable to clients (F-3/WS-A).
            allow update: if canEditEvent(eventId)
              && keysUnchanged(['fileId', 'name', 'mimeType', 'iconLink', 'webViewLink',
                                'addedBy', 'addedAt']);
            allow delete: if canEditEvent(eventId);
          }

          // Quotes/estimates (artist-covered expenses): member read; PM/admin author + decide.
          // Status changes (approve/reject) ride the update gate, so tech/dept-lead can't decide.
          match /quotes/{quoteId} {
            allow read: if isAdmin() || isMember(eventId);
            allow create: if canEditEvent(eventId)
              && request.resource.data.createdBy == request.auth.uid
              && nonEmptyStr(request.resource.data, 'title')
              && fieldIn(request.resource.data, 'status', ['draft', 'sent', 'approved', 'rejected']);
            allow update: if canEditEvent(eventId)
              && request.resource.data.createdBy == resource.data.createdBy // owner immutable
              && nonEmptyStr(request.resource.data, 'title')
              && fieldIn(request.resource.data, 'status', ['draft', 'sent', 'approved', 'rejected']);
            allow delete: if canEditEvent(eventId);
          }
        }

        // Per-stage technical production record (house package): member read; PM/admin write.
        match /production/{recordId} {
          allow read: if isAdmin() || isMember(eventId);
          allow write: if canEditEvent(eventId);

          // Attachments (stage plots / CAD / maps) — one doc per file; member read, PM/admin write.
          match /attachments/{attachId} {
            allow read: if isAdmin() || isMember(eventId);
            allow write: if canEditEvent(eventId);
          }
        }
      }

      // Event-level production record (general/tech-operational): member read; PM/admin write.
      match /production/{recordId} {
        allow read: if isAdmin() || isMember(eventId);
        allow write: if canEditEvent(eventId);

        // Attachments (plots / CAD / maps) — one doc per file; member read, PM/admin write.
        match /attachments/{attachId} {
          allow read: if isAdmin() || isMember(eventId);
          allow write: if canEditEvent(eventId);
        }
      }

      // Per-event contact attachments (join → global contacts/{id}): member read; PM/admin write.
      match /contacts/{attachId} {
        allow read: if isAdmin() || isMember(eventId);
        allow create, update, delete: if canEditEvent(eventId);
      }

      // Event documents (Documents PR 4): Drive files in the event's linked folder,
      // recorded per event and grouped by schedule day key. Doc id = the Drive file id.
      // Members read; PM/admin manage. Audit fields pinned + immutable.
      match /documents/{docId} {
        allow read: if isAdmin() || isMember(eventId);
        // Server-only (S8): registered by the registerEventDocument callable (Admin SDK), which
        // verifies the file lives in the event's linked Drive folder (F-1). No client create.
        allow create: if false;
        // Client curation is limited to day / categoryId / displayName; the audit fields AND the
        // Drive source metadata the callable recorded are immutable to clients (F-3/WS-A).
        allow update: if canEditEvent(eventId)
          && keysUnchanged(['fileId', 'name', 'mimeType', 'iconLink', 'webViewLink',
                            'uploadedBy', 'uploadedAt']);
        allow delete: if canEditEvent(eventId);
      }

      // Schedule days (redesign — planning/archive/feature/SCHEDULE_REDESIGN.md): one doc per calendar day,
      // doc id = the 'YYYY-MM-DD' date key (one-card-per-date is structural), items embedded
      // in the day. Member read; PM/admin write. Per-item googleCalendarEventId is reconciled
      // server-side — rules can't practically gate fields inside an embedded array, so the
      // push callable is authoritative for calendar state.
      match /scheduleDays/{dayKey} {
        // Shared shape gate for create + update: the stored date always equals the doc
        // id, the day type is a known key, and items is a (possibly empty) list.
        function validDayShape() {
          return request.resource.data.get('date', '') == dayKey
            && fieldIn(request.resource.data, 'dayType', ['travel', 'loadIn', 'show', 'loadOut', 'offDay'])
            && request.resource.data.get('items', []) is list;
        }
        allow read: if isAdmin() || isMember(eventId);
        allow create: if canEditEvent(eventId)
          && validDayShape()
          && dayKey.matches('\\d{4}-\\d{2}-\\d{2}')
          && request.resource.data.createdBy == request.auth.uid;
        allow update: if canEditEvent(eventId)
          && validDayShape()
          && keysUnchanged(['createdBy'])
          // Optimistic-concurrency guard (WS-G): a client writing `revision` must increment it by
          // exactly 1, so a stale whole-day overwrite (lost update) is rejected server-side. A
          // client that omits `revision` (the pre-Hosting client; the Admin-SDK reconcile bypasses
          // rules) is unaffected — drop the `!('revision' in …)` escape once every client writes it.
          && (!('revision' in request.resource.data)
              || request.resource.data.revision == resource.data.get('revision', 0) + 1);
        allow delete: if canEditEvent(eventId);
      }

      // Booked advance-call inbox (Phase 11b sync): synced + auto-attached by the Admin SDK;
      // PM/admin resolve from the review queue. Member read. Manual ATTACH is moving to the atomic
      // attachCallBooking callable (WS-G); dismiss stays a client update. The client write stays
      // open until the new client ships, then tighten to dismiss-only (server owns attach).
      match /callBookings/{bookingId} {
        allow read: if isAdmin() || isMember(eventId);
        allow create, update, delete: if canEditEvent(eventId);
      }

      // Flags/comments (event-level): PM + dept-lead (+ admin) author; authors modify own.
      match /flags/{flagId} {
        allow read: if isAdmin() || isMember(eventId);
        allow create: if canFlagEvent(eventId)
          && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if isAdmin()
          || (isSignedIn() && resource.data.createdBy == request.auth.uid && canFlagEvent(eventId));
      }
    }
  }
}
