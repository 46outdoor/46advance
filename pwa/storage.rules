rules_version = '2';

// Production attachments (stage plots / CAD / site maps) under events/{eventId}/...
// Membership is read from Firestore (per-event RBAC). Internal tool.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.get('admin', false) == true;
    }
    // Approved-user gate — mirrors firestore.rules / the `approved` custom claim.
    // Pending/revoked accounts (no `approved` claim) are blocked, not just in the UI.
    // `.get(claim, false)` tolerates tokens that omit the claim (no eval warning).
    function isApproved() {
      return isSignedIn() && request.auth.token.get('approved', false) == true;
    }
    function isActiveUser() {
      return isAdmin() || isApproved();
    }
    function isMember(eventId) {
      return isActiveUser()
        && firestore.exists(/databases/(default)/documents/events/$(eventId)/members/$(request.auth.uid));
    }
    function isPM(eventId) {
      return isMember(eventId)
        && firestore.get(/databases/(default)/documents/events/$(eventId)/members/$(request.auth.uid)).data.role == 'production-manager';
    }
    function canEditEvent(eventId) {
      return isAdmin() || isPM(eventId);
    }
    // 25 MB cap; allow PDFs/images and CAD (DWG/DXF often arrive as octet-stream).
    function validUpload() {
      return request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType in [
          'application/pdf', 'image/png', 'image/jpeg', 'application/octet-stream'
        ];
    }

    match /events/{eventId}/{allPaths=**} {
      allow read: if isAdmin() || isMember(eventId);
      allow write: if canEditEvent(eventId) && validUpload();
      allow delete: if canEditEvent(eventId);
    }

    // Template logos — admin-authored; any approved user reads.
    match /templates/{allPaths=**} {
      allow read: if isActiveUser();
      allow write: if isAdmin() && validUpload();
      allow delete: if isAdmin();
    }
    // Shared default brand logos (config/branding) — admin-managed; any approved user reads.
    match /branding/{allPaths=**} {
      allow read: if isActiveUser();
      allow write: if isAdmin() && validUpload();
      allow delete: if isAdmin();
    }
    // Contact directory photos live at contacts/photos/{uploaderUid}/{file}. Any approved user
    // reads; a user may only write/delete within their OWN uid folder (admin: any) — previously
    // any approved user could overwrite/delete any photo. Legacy flat photos
    // (contacts/photos/{file}, pre-uid-prefix) stay readable; only an admin can mutate them.
    match /contacts/photos/{uid}/{fileName} {
      allow read: if isActiveUser();
      allow write: if (isAdmin() || (isActiveUser() && uid == request.auth.uid)) && validUpload();
      allow delete: if isAdmin() || (isActiveUser() && uid == request.auth.uid);
    }
    match /contacts/photos/{fileName} {
      allow read: if isActiveUser();
      allow write, delete: if isAdmin();
    }
  }
}
